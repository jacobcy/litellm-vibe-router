# LiteLLM Test Configuration Example
# Copy to .env and fill in your actual values

# ==========================================
# Test Environment
# ==========================================
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-litellm-master-key-CHANGE-THIS
LITELLM_REMOTE_URL=http://your-server.com:4000

# ==========================================
# CLIProxyAPI Configuration (Port 8317)
# ==========================================
CLIPROXY_BASE_URL=http://localhost:8317
CHAT_AUTO_API_KEY=sk-auto-chat-proxy-key-CHANGE-THIS

# ==========================================
# Backend API Keys (for reference/debugging)
# ==========================================
# Level 2: New API
NEW_API_KEY=your-new-api-key
NEW_API_BASE=http://localhost:3000/v1
NEW_API_ANTHROPIC_BASE=http://localhost:3000

# Level 3: Volces Ark API
ARK_API_KEY=your-ark-api-key
ARK_OPENAI_BASE=https://ark.cn-beijing.volces.com/api/coding
ARK_CLAUDE_BASE=https://ark.cn-beijing.volces.com/api/coding
